# ===========================================
# Ask Xuan - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# Most variables are OPTIONAL - the app can run in "static mode" with zero configuration

# ===========================================
# Core Configuration (Optional)
# ===========================================
# Without these, the app runs in "static mode" (Landing, Docs, Blog only)

# Application URL (default: http://localhost:3377)
VITE_APP_URL=http://localhost:3377

# Runtime database connection string (PostgreSQL)
# Without this, user authentication and all user-related features are disabled
# Supabase: use the pooled transaction connection string, usually port 6543.
DATABASE_URL=

# Optional migration database connection string.
# Supabase: prefer the direct connection string for Drizzle migrations, usually port 5432.
# If omitted, drizzle-kit falls back to DATABASE_URL.
DATABASE_MIGRATION_URL=

# ===========================================
# Authentication (Supabase Auth)
# ===========================================

# Supabase project URL and publishable/anon key.
# The publishable key is safe to expose to the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth providers are configured in the Supabase Dashboard.

# Cloudflare Turnstile Captcha (optional)
VITE_TURNSTILE_CAPTCHA_ENABLED=false
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===========================================
# Email Service (Optional)
# ===========================================
# Required only when using project-managed transactional emails.

# Email provider: "resend" or "custom"
EMAIL_PROVIDER=
EMAIL_FROM=

# Email verification (default: false)
# Set to true to require email verification on sign up
EMAIL_VERIFICATION_ENABLED=false

# For Resend provider
RESEND_API_KEY=

# For Custom SMTP provider
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASSWORD=

# ===========================================
# Storage Service (Optional)
# ===========================================
# S3-compatible storage for file uploads

STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=auto
STORAGE_BUCKET_NAME=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=

# ===========================================
# Payment (Optional, configured in admin panel)
# ===========================================
# Payment configuration is stored in database and managed via admin panel
# These are only needed if you want to override database settings

# Stripe Price IDs (for pricing display)
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PRO_YEARLY_PRICE_ID=
VITE_STRIPE_LIFETIME_PRICE_ID=

# ===========================================
# Analytics (Optional)
# ===========================================

# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# ===========================================
# Other Settings
# ===========================================

# Currency display (default: USD)
VITE_CURRENCY=USD

# Environment (production/development)
VITE_ENV=development
